{
  "manifest_version": 3,
  "name": "Vue Printer - C-LODOP Print Extension",
  "version": "1.0.0",
  "description": "Browser extension for C-LODOP printing integration with custom templates support",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://*:*/CLodopfuncs.js https://*:*/CLodopfuncs.js; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/auth.html",
    "default_icon": {
      "16": "icons/icon16.svg"
    },
    "default_title": "Vue Printer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg"
  },
  "options_ui": {
    "page": "index.html#/admin/home",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "templates/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}