{
  "manifest_version": 3,
  "name": "Vue Printer - C-LODOP Print Extension",
  "version": "1.1.0",
  "description": "Browser extension for C-LODOP printing integration with WebSocket support for cloud print tasks",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "ws://*/*",
    "wss://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://127.0.0.1:*; object-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws: wss: http: https:"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/auth.html",
    "default_icon": {
      "16": "icons/icon16.svg"
    },
    "default_title": "Vue Printer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg"
  },
  "options_ui": {
    "page": "index.html#/admin/home",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "print-preview.html", "templates/*", "assets/*", "services/*"],
      "matches": ["<all_urls>"]
    }
  ]
}